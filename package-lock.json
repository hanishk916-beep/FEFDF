import Sidebar from "../components/Sidebar";

function Profile() {
  const crewProfile = {
    employeeId: "EMP001",
    name: "John Smith",
    role: "Captain",
    experience: "10 Years",
    licenseNumber: "ATPL-987654",
    licenseStatus: "Valid",
    email: "john.smith@airline.com",
    phone: "+91 9876543210",
  };

  return (
    <div style={{ display: "flex" }}>
      <Sidebar />

      <div style={{ padding: "20px", flex: 1 }}>
        <h1>👤 Crew Profile</h1>

        <div
          style={{
            border: "1px solid #ddd",
            padding: "20px",
            borderRadius: "10px",
            maxWidth: "600px",
          }}
        >
          <h2>{crewProfile.name}</h2>

          <p>
            <strong>Employee ID:</strong>{" "}
            {crewProfile.employeeId}
          </p>

          <p>
            <strong>Role:</strong>{" "}
            {crewProfile.role}
          </p>

          <p>
            <strong>Experience:</strong>{" "}
            {crewProfile.experience}
          </p>

          <p>
            <strong>License Number:</strong>{" "}
            {crewProfile.licenseNumber}
          </p>

          <p>
            <strong>License Status:</strong>{" "}
            {crewProfile.licenseStatus}
          </p>

          <p>
            <strong>Email:</strong>{" "}
            {crewProfile.email}
          </p>

          <p>
            <strong>Phone:</strong>{" "}
            {crewProfile.phone}
          </p>

          <button
            style={{
              padding: "10px 20px",
              marginTop: "10px",
              cursor: "pointer",
            }}
          >
            Edit Profile
          </button>
        </div>
      </div>
    </div>
  );
}

export default Profile;